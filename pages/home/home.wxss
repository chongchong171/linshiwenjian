/* pages/home/home.wxss */

.home-container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 视频背景 */
.video-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.bg-video {
  width: 100%;
  height: 100%;
}

/* 标题区域 */
.title-area {
  position: absolute;
  top: 20%;
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 10;
}

.game-title {
  display: block;
  font-size: 80rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
  margin-bottom: 20rpx;
}

.game-subtitle {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}

/* 开始游戏按钮 */
.start-area {
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 10;
}

.start-btn {
  width: 400rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  box-shadow: 0 10rpx 40rpx rgba(102, 126, 234, 0.5);
}

.btn-text {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

/* 底部提示 */
.footer-area {
  position: absolute;
  bottom: 10%;
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 10;
}

.footer-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.5);
}
