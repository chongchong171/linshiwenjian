/* pages/home/home.wxss */

.home-container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #1a1a2e;
}

/* 视频背景 */
.bg-video {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

/* 标题区域 */
.title-area {
  position: absolute;
  top: 15%;
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 10;
}

.game-title {
  display: block;
  font-size: 90rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.6);
  margin-bottom: 16rpx;
  letter-spacing: 8rpx;
}

.game-subtitle {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 2rpx 15rpx rgba(0, 0, 0, 0.5);
}

/* 开始游戏按钮 */
.start-area {
  position: absolute;
  bottom: 15%;
  left: 0;
  width: 100%;
  text-align: center;
  z-index: 10;
}

.start-btn {
  width: 420rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  border-radius: 55rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto;
  box-shadow: 0 12rpx 50rpx rgba(67, 233, 123, 0.5);
  border: none;
}

.start-btn::after {
  border: none;
}

.btn-text {
  font-size: 38rpx;
  font-weight: bold;
  color: #1a1a2e;
}
