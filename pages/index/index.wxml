<!--pages/index/index.wxml-->
<view class="home">
  <!-- 视频背景 -->
  <video
    id="homeVideo"
    class="bg-video"
    src="/static/videos/home-intro.mp4"
    autoplay="true"
    loop="true"
    muted="true"
    object-fit="cover"
    show-center-play-btn="false"
    show-play-btn="false"
    enable-progress-gesture="false"
    binderror="onVideoError"
  />

  <!-- 品牌 -->
  <view class="brand">
    <text class="logo">🌿</text>
    <text class="name">绿了个植</text>
    <text class="sub">滑动消除 · 收集植物</text>
  </view>

  <!-- 今日主题 -->
  <view class="theme-card">
    <text class="badge">📅 今日</text>
    <text class="title">{{themeName}}</text>
    <text class="desc">{{themeDesc}}</text>
  </view>

  <!-- 游戏按钮 -->
  <view class="play-btns">
    <view class="play main" bindtap="onStartGame">
      <text class="icon">🎮</text>
      <text class="title">开始游戏</text>
      <text class="sub">入门</text>
    </view>
    <view class="play daily" bindtap="onStartDaily">
      <text class="icon">⚡</text>
      <text class="title">每日挑战</text>
      <text class="sub">地狱</text>
    </view>
  </view>

  <!-- 底部 -->
  <view class="bottom">
    <view class="item" bindtap="onGoGarden">
      <text class="icon">🌻</text>
      <text class="text">花园</text>
      <text class="num">{{gardenCount}}</text>
    </view>
    <view class="item" bindtap="onGoRank">
      <text class="icon">🏆</text>
      <text class="text">排行</text>
      <text class="num">冲冲冲</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats">
    <text>玩了 {{stats.totalGames}} 局</text>
    <text>通关 {{stats.totalPass}} 次</text>
    <text>消除 {{stats.totalPlants}} 株</text>
  </view>
</view>
