/* pages/index/index.wxss — 游戏首页 */

page {
  background: #0d1117;
}

.home {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 60rpx;
  background: linear-gradient(180deg, #1a0533 0%, #0d1117 40%, #0a1628 100%);
  position: relative;
  overflow: hidden;
}

/* ========== 视频背景 ========== */

.bg-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.brand,
.theme-card,
.play-btns,
.bottom,
.stats {
  position: relative;
  z-index: 1;
}

/* ========== 品牌 ========== */

.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.name {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 16rpx rgba(124, 77, 255, 0.5);
}

.sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.35);
}

/* ========== 主题卡片 ========== */

.theme-card {
  width: 100%;
  border-radius: 28rpx;
  padding: 36rpx;
  text-align: center;
  background: linear-gradient(145deg, rgba(124, 77, 255, 0.2), rgba(83, 109, 254, 0.1));
  border: 2rpx solid rgba(124, 77, 255, 0.35);
  box-shadow: 0 8rpx 32rpx rgba(124, 77, 255, 0.2);
  margin-bottom: 48rpx;
}

.badge {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  display: block;
}

/* ========== 游戏按钮 ========== */

.play-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 48rpx;
}

.play {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44rpx 20rpx;
  border-radius: 28rpx;
}

.play:active {
  transform: scale(0.95);
}

.main {
  background: linear-gradient(135deg, #7c4dff, #536dfe);
  box-shadow: 0 8rpx 24rpx rgba(124, 77, 255, 0.4);
}

.daily {
  background: linear-gradient(135deg, #ff6d00, #ff9100);
  box-shadow: 0 8rpx 24rpx rgba(255, 109, 0, 0.4);
}

.icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.play .title {
  font-size: 32rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 8rpx;
}

.play .sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 底部 ========== */

.bottom {
  display: flex;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.1);
}

.item .icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.item .text {
  font-size: 26rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 4rpx;
}

.item .num {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* ========== 统计 ========== */

.stats {
  display: flex;
  justify-content: center;
  gap: 28rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.2);
}
