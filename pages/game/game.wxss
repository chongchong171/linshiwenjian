/* pages/game/game.wxss */

.game-container {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部信息栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 0 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.level-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.level-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.level-id {
  font-size: 24rpx;
  color: #666;
}

.score-info, .moves-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-label, .moves-label {
  font-size: 24rpx;
  color: #666;
}

.score-value, .moves-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 游戏区域 */
.game-area {
  flex: 1;
  position: relative;
  margin: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  overflow: auto;
}

.game-message {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: white;
  font-size: 32rpx;
}

/* 植物网格 - 实现多层堆叠效果 */
.plant-grid {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 500rpx;
}

/* 植物单元格 */
.plant-cell {
  position: absolute;
  width: 160rpx;  /* 80px * 2 = 160rpx */
  height: 160rpx; /* 80px * 2 = 160rpx */
  transition: all 0.3s ease;
}

.plant-cell.visible {
  opacity: 1;
}

.plant-cell.hidden {
  opacity: 0.3;
  filter: grayscale(100%);
  pointer-events: none;
}

.plant-inner {
  width: 100%;
  height: 100%;
  background: white;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

/* 堆叠效果 - 上层植物有阴影 */
.plant-cell[style*="z-index: 1"] .plant-inner,
.plant-cell[style*="z-index: 2"] .plant-inner,
.plant-cell[style*="z-index: 3"] .plant-inner {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.plant-icon {
  font-size: 80rpx;
}

/* 底部信息栏 */
.bottom-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx 30rpx 0 0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.remaining-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.remaining-label {
  font-size: 24rpx;
  color: #666;
}

.remaining-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF5722;
}

.powerup-bar {
  display: flex;
  gap: 20rpx;
}

.powerup-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  min-width: 80rpx;
}

.powerup-icon {
  font-size: 40rpx;
  margin-bottom: 5rpx;
}

.powerup-count {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  text-align: center;
  min-width: 500rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-score, .modal-moves {
  font-size: 32rpx;
  color: #666;
  margin: 10rpx 0;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-buttons button {
  flex: 1;
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.btn-restart {
  background: #4CAF50;
  color: white;
}

.btn-next {
  background: #2196F3;
  color: white;
}

.btn-share {
  background: #FF9800;
  color: white;
}

/* 动画效果 */
@keyframes eliminate {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.5;
  }
  100% {
    transform: scale(0);
    opacity: 0;
  }
}

.plant-cell.eliminating {
  animation: eliminate 0.5s ease-out forwards;
}
