/* pages/game/game.wxss */

page {
  background: #f5f0e1;
}

.game-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #e8f5e9 0%, #f1f8e9 50%, #f5f0e1 100%);
  overflow: hidden;
}

/* ========== 顶部栏 ========== */

.header {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  background: rgba(76, 175, 80, 0.95);
  color: white;
  flex-shrink: 0;
}

.back-btn {
  font-size: 36rpx;
  padding: 8rpx;
}

.theme-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.theme-name {
  font-size: 28rpx;
  font-weight: bold;
}

.level-tag {
  font-size: 20rpx;
  opacity: 0.8;
}

.timer {
  font-size: 24rpx;
  font-family: monospace;
}

/* ========== 进度条 ========== */

.progress-bar {
  height: 32rpx;
  background: rgba(0, 0, 0, 0.1);
  position: relative;
  margin: 0 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #66bb6a, #43a047);
  border-radius: 16rpx;
  transition: width 0.3s ease;
}

.progress-text {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.5);
}

/* ========== 游戏区域 ========== */

.game-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

.cards-container {
  position: relative;
  width: 100%;
  height: 100%;
}

.card {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.15s ease;
}

.card.active {
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.25);
}

.card.active:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.card.covered {
  filter: brightness(0.65);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.card.highlighted {
  animation: pulse 0.6s ease-in-out infinite;
  box-shadow: 0 0 20rpx rgba(76, 175, 80, 0.8);
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.card-image {
  width: 90rpx;
  height: 90rpx;
}

/* ========== 道具栏 ========== */

.props-bar {
  height: 140rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 16rpx;
  background: rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.prop-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  height: 110rpx;
  border-radius: 24rpx;
  background: white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  padding: 12rpx 0;
}

.prop-item:active {
  transform: scale(0.92);
}

.prop-icon {
  font-size: 40rpx;
  line-height: 1;
}

.prop-name {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

/* ========== 连击提示 ========== */

.combo-tip {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 999;
  animation: comboAnim 0.8s ease forwards;
}

.combo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff5722;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

@keyframes comboAnim {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
  30% { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
  100% { opacity: 0; transform: translate(-50%, -60%) scale(1); }
}

/* ========== 弹窗通用 ========== */

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal {
  background: white;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  width: 85%;
  max-width: 600rpx;
  text-align: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.modal-sub {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 32rpx;
  display: block;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #66bb6a, #43a047);
  color: white;
}

.modal-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.share {
  width: 100%;
  background: linear-gradient(135deg, #42a5f5, #1e88e5);
  color: white;
  margin-top: 8rpx;
}

/* ========== 失败弹窗 ========== */

.fail-modal .modal-title {
  color: #ff5722;
}

/* ========== 通关弹窗 ========== */

.pass-modal .modal-title {
  color: #43a047;
}

.pass-info {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.pass-time, .pass-combo {
  font-size: 24rpx;
  color: #666;
}

.card-reward {
  margin-bottom: 24rpx;
}

.reward-label {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 12rpx;
}

.reward-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 40rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
}

.reward-card.legendary {
  background: linear-gradient(135deg, #fff8e1, #ffecb3);
  border-color: #ffd54f;
}

.reward-card.rare {
  background: linear-gradient(135deg, #e3f2fd, #bbdefb);
  border-color: #64b5f6;
}

.reward-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.reward-rarity {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.reward-rarity.legendary {
  color: #f9a825;
}

.reward-rarity.rare {
  color: #1e88e5;
}

/* ========== 广告弹窗 ========== */

.ad-modal .modal-title {
  color: #ff9800;
}
