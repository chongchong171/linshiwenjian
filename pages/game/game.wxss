/* pages/game/game.wxss */

.game-container {
  width: 100vw;
  height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部信息栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 0 0 20rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.level-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.level-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.level-id {
  font-size: 22rpx;
  color: #666;
}

.score-info, .moves-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-label, .moves-label {
  font-size: 22rpx;
  color: #666;
}

.score-value, .moves-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 游戏区域 */
.game-area {
  flex: 1;
  position: relative;
  margin: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  overflow: auto;
}

.game-message {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: white;
  font-size: 32rpx;
}

/* 植物网格 */
.plant-grid {
  position: relative;
  width: 100%;
  height: 100%;
  min-height: 400rpx;
}

/* 植物单元格 */
.plant-cell {
  position: absolute;
  width: 120rpx;
  height: 120rpx;
  transition: all 0.3s ease;
}

.plant-cell.visible {
  opacity: 1;
  cursor: pointer;
}

.plant-cell.hidden {
  opacity: 0.6;
  pointer-events: none;
}

.plant-inner {
  width: 100%;
  height: 100%;
  background: white;
  border-radius: 16rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
}

/* 可拾取植物 - 白色背景 + 绿色边框 */
.plant-cell.visible .plant-inner {
  background: white;
  border-color: #4CAF50;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

/* 可拾取植物 - 点击效果 */
.plant-cell.visible:active .plant-inner {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

/* 被遮挡植物 - 红色背景 */
.plant-cell.hidden .plant-inner {
  background: #ffebee;
  border-color: #f44336;
  box-shadow: 0 2rpx 8rpx rgba(244, 67, 54, 0.3);
}

/* 抖动动画 - 点击被挡植物 */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-4rpx); }
  20%, 40%, 60%, 80% { transform: translateX(4rpx); }
}

.plant-cell.shake {
  animation: shake 0.5s ease-in-out;
}

/* 堆叠效果 */
.plant-cell[style*="z-index: 2"] .plant-inner,
.plant-cell[style*="z-index: 3"] .plant-inner,
.plant-cell[style*="z-index: 4"] .plant-inner {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.35);
}

.plant-icon {
  font-size: 60rpx;
}

/* 底部卡槽区域 */
.slot-area {
  background: rgba(255, 255, 255, 0.95);
  padding: 16rpx 24rpx;
  border-radius: 20rpx 20rpx 0 0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.slot-container {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.slot-item {
  width: 80rpx;
  height: 80rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx solid rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.slot-item.filled {
  background: white;
  border-color: #4CAF50;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.slot-item.empty {
  background: rgba(0, 0, 0, 0.05);
}

.slot-inner {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.slot-icon {
  font-size: 50rpx;
}

/* 暂存区 - 移出三张牌 */
.temp-area {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  min-height: 80rpx;
  padding: 8rpx;
}

.temp-item {
  width: 80rpx;
  height: 80rpx;
  background: white;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 2rpx solid #2196F3;
  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.3);
  transition: all 0.3s ease;
  animation: fadeIn 0.3s ease-out;
}

.temp-item:active {
  transform: scale(0.9);
  background: #e3f2fd;
}

.temp-icon {
  font-size: 50rpx;
}

/* 淡入动画 */
@keyframes fadeIn {
  0% {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.remaining-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
}

.remaining-label {
  font-size: 22rpx;
  color: #666;
}

.remaining-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF5722;
}

/* 道具栏 */
.powerup-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top: 2rpx solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.powerup-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  min-width: 90rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s ease;
  cursor: pointer;
}

.powerup-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.powerup-item.disabled {
  opacity: 0.5;
  filter: grayscale(100%);
  pointer-events: none;
}

.powerup-icon {
  font-size: 44rpx;
  margin-bottom: 4rpx;
}

.powerup-count {
  font-size: 26rpx;
  font-weight: bold;
  color: white;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  text-align: center;
  min-width: 500rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.3);
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-score, .modal-moves {
  font-size: 32rpx;
  color: #666;
  margin: 10rpx 0;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-buttons button {
  flex: 1;
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}

.btn-restart {
  background: #4CAF50;
  color: white;
}

.btn-next {
  background: #2196F3;
  color: white;
}

.btn-share {
  background: #FF9800;
  color: white;
}

/* 植物飞入卡槽动画 */
.slot-item.flying {
  animation: flyToSlot 0.5s ease-out;
}

@keyframes flyToSlot {
  0% {
    transform: scale(1.5);
    opacity: 0;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.7;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 消除动画 */
@keyframes eliminate {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.8;
  }
  100% {
    transform: scale(0);
    opacity: 0;
  }
}

.slot-item.eliminating {
  animation: eliminate 0.5s ease-out forwards;
}

/* 游戏结束弹窗动画 */
.modal-overlay {
  animation: fadeIn 0.3s ease-out;
}

.modal-content {
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  0% {
    transform: translateY(50rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

/* 按钮点击效果 */
.modal-buttons button:active {
  transform: scale(0.95);
}

/* 加载动画 */
.game-message {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: white;
  font-size: 32rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

/* 顶部信息栏动画 */
.top-bar {
  animation: slideDown 0.3s ease-out;
}

@keyframes slideDown {
  0% {
    transform: translateY(-100%);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

/* 游戏区域动画 */
.game-area {
  animation: fadeIn 0.5s ease-out;
}

/* 底部卡槽区域动画 */
.slot-area {
  animation: slideUp 0.3s ease-out;
}

/* 道具栏动画 */
.powerup-bar {
  animation: slideUp 0.3s ease-out 0.1s both;
}

/* 植物网格动画 */
.plant-grid {
  animation: fadeIn 0.5s ease-out;
}

/* 植物单元格入场动画 */
.plant-cell {
  animation: plantAppear 0.3s ease-out;
}

@keyframes plantAppear {
  0% {
    transform: scale(0);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}
