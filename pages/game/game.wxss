/* pages/game/game.wxss — 游戏感，全屏 */

page {
  background: #0d1117;
}

.game {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #1a0533 0%, #0d1117 50%, #0a1628 100%);
}

/* ========== 顶部栏 ========== */

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  z-index: 500;
  background: linear-gradient(180deg, rgba(13, 17, 23, 0.95) 0%, transparent 100%);
}

.back {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.info-center {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.theme {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.level {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
}

.timer {
  font-size: 26rpx;
  color: #fff;
  font-family: monospace;
  background: rgba(255, 255, 255, 0.08);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 游戏牌区 ========== */

.board {
  width: 100%;
  height: 100%;
  position: relative;
  padding-top: 88rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* ========== 卡片 ========== */

.card {
  position: absolute;
  width: 130rpx;
  height: 130rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #2a1f4d 0%, #1a1235 100%);
  border: 2rpx solid rgba(138, 100, 210, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
  display: flex;
  justify-content: center;
  align-items: center;
  transition: transform 0.12s ease, box-shadow 0.12s ease;
  overflow: hidden;
}

.card image {
  width: 90rpx;
  height: 90rpx;
}

.card.active {
  border-color: rgba(138, 100, 210, 0.7);
  box-shadow: 0 6rpx 20rpx rgba(138, 100, 210, 0.3);
}

.card.active:active {
  transform: scale(0.92) !important;
}

.card.covered {
  background: linear-gradient(145deg, #1a1528 0%, #12101e 100%);
  border-color: rgba(80, 60, 120, 0.3);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.card.covered image {
  filter: brightness(0.4) saturate(0.2);
}

.shade {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(20, 15, 40, 0.6);
  border-radius: 20rpx;
}

.card.glow {
  animation: cardPulse 0.8s ease-in-out infinite;
  border-color: rgba(255, 213, 79, 0.8);
  box-shadow: 0 0 24rpx rgba(255, 213, 79, 0.5);
}

@keyframes cardPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}

.card.animating {
  animation: cardEliminate 0.35s ease forwards;
}

@keyframes cardEliminate {
  0% { transform: scale(1); opacity: 1; }
  30% { transform: scale(1.25); opacity: 1; }
  100% { transform: scale(0); opacity: 0; }
}

/* ========== 底部收集栏 ========== */

.tray {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 500;
  padding: 16rpx 24rpx 32rpx;
  background: linear-gradient(0deg, rgba(13, 17, 23, 0.95) 0%, transparent 100%);
}

.tray-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  text-align: center;
  margin-bottom: 12rpx;
}

.tray-slots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.slot {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
}

.slot.filled {
  background: rgba(138, 100, 210, 0.15);
  border-color: rgba(138, 100, 210, 0.4);
}

.slot image {
  width: 60rpx;
  height: 60rpx;
}

/* ========== 连击特效 ========== */

.combo {
  position: fixed;
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: comboBurst 0.7s ease forwards;
  pointer-events: none;
}

.combo-num {
  font-size: 88rpx;
  font-weight: 900;
  color: #ffd54f;
  text-shadow: 0 4rpx 20rpx rgba(255, 152, 0, 0.8), 0 0 60rpx rgba(255, 152, 0, 0.4);
  line-height: 1;
}

.combo-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  margin-top: 4rpx;
}

@keyframes comboBurst {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
  25% { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
  45% { transform: translate(-50%, -50%) scale(1); }
  100% { opacity: 0; transform: translate(-50%, -65%) scale(0.8); }
}

/* ========== 道具栏 ========== */

.tools {
  position: fixed;
  bottom: 160rpx;
  right: 24rpx;
  z-index: 600;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tool {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tool:active {
  transform: scale(0.85);
  background: rgba(255, 255, 255, 0.2);
}

.tool-icon {
  font-size: 36rpx;
  line-height: 1;
}

.tool-name {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 2rpx;
}

/* ========== 弹窗 ========== */

.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  animation: fadeIn 0.25s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal {
  width: 78%;
  max-width: 540rpx;
  border-radius: 32rpx;
  padding: 56rpx 36rpx 36rpx;
  text-align: center;
  animation: modalPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalPop {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.modal.pass {
  background: linear-gradient(160deg, #2d1b69 0%, #1a0a3e 100%);
  border: 2rpx solid rgba(138, 100, 210, 0.5);
  box-shadow: 0 20rpx 60rpx rgba(45, 27, 105, 0.6);
}

.modal.fail {
  background: linear-gradient(160deg, #4a1528 0%, #2a0a18 100%);
  border: 2rpx solid rgba(255, 87, 34, 0.4);
  box-shadow: 0 20rpx 60rpx rgba(74, 21, 40, 0.6);
}

.modal-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.modal-title {
  font-size: 44rpx;
  font-weight: 900;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.modal-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  display: block;
  margin-bottom: 32rpx;
}

/* ========== 数据 ========== */

.stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.val {
  font-size: 40rpx;
  font-weight: 900;
  color: #ffd54f;
  line-height: 1;
}

.lbl {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

/* ========== 奖励 ========== */

.reward {
  margin-bottom: 32rpx;
}

.reward-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 16rpx;
}

.reward-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 44rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
}

.reward-card.legendary {
  background: linear-gradient(135deg, rgba(255, 213, 79, 0.2), rgba(255, 152, 0, 0.15));
  border-color: rgba(255, 213, 79, 0.5);
  box-shadow: 0 0 30rpx rgba(255, 213, 79, 0.3);
}

.reward-card.rare {
  background: linear-gradient(135deg, rgba(100, 181, 246, 0.2), rgba(30, 136, 229, 0.15));
  border-color: rgba(100, 181, 246, 0.5);
  box-shadow: 0 0 20rpx rgba(100, 181, 246, 0.3);
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
}

.reward-card.legendary .tag {
  color: #ffd54f;
}

.reward-card.rare .tag {
  color: #64b5f6;
}

/* ========== 按钮 ========== */

.btns {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
  text-align: center;
}

.btn.primary {
  background: linear-gradient(135deg, #7c4dff, #536dfe);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(124, 77, 255, 0.4);
}

.btn.primary:active {
  transform: scale(0.95);
}

.btn.ghost {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.btn.ghost:active {
  transform: scale(0.95);
}

.share {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: transparent;
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.share::after {
  border: none;
}
