<!--pages/game/game.wxml-->
<view class="game-container">
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="level-info">
      <text class="level-name">{{themeName}}</text>
      <text class="level-id">第{{currentLevel}}关</text>
    </view>
    <view class="score-info">
      <text class="score-label">分数</text>
      <text class="score-value">{{score}}</text>
    </view>
    <view class="moves-info">
      <text class="moves-label">步数</text>
      <text class="moves-value">{{moves}}</text>
    </view>
  </view>

  <!-- 游戏区域 -->
  <view class="game-area" 
    bindtouchstart="onTouchStart" 
    bindtouchmove="onTouchMove" 
    bindtouchend="onTouchEnd">
    
    <!-- 植物网格 -->
    <view class="plant-grid">
      <view 
        wx:for="{{visiblePlants}}" 
        wx:key="id"
        class="plant-cell {{item.visible ? 'visible' : 'hidden'}}"
        data-plant-id="{{item.id}}"
        style="left: {{item.col * 60 + item.layer * 10}}px; top: {{item.row * 60 + item.layer * 10}}px; z-index: {{item.layer * 100 + item.row * 10 + item.col}}">
        <image 
          class="plant-image" 
          src="/static/plants/plant-{{item.type}}.png" 
          mode="aspectFit"
        />
      </view>
    </view>
    
    <!-- 滑动路径显示 -->
    <view class="swipe-path" wx:if="{{currentSwipePath.length > 0}}">
      <view 
        wx:for="{{currentSwipePath}}" 
        wx:key="id"
        class="swipe-point"
        style="left: {{item.col * 60 + item.layer * 10 + 30}}px; top: {{item.row * 60 + item.layer * 10 + 30}}px">
      </view>
    </view>
  </view>

  <!-- 底部信息栏 -->
  <view class="bottom-bar">
    <view class="remaining-info">
      <text class="remaining-label">剩余</text>
      <text class="remaining-value">{{remainingCount}}</text>
    </view>
    <view class="powerup-bar">
      <view class="powerup-item" bindtap="onUsePowerUp" data-type="magnifier">
        <image class="powerup-icon" src="/static/icons/magnifier.png" />
        <text class="powerup-count">{{powerUps.magnifier}}</text>
      </view>
      <view class="powerup-item" bindtap="onUsePowerUp" data-type="weedkiller">
        <image class="powerup-icon" src="/static/icons/weedkiller.png" />
        <text class="powerup-count">{{powerUps.weedkiller}}</text>
      </view>
      <view class="powerup-item" bindtap="onUsePowerUp" data-type="shuffle">
        <image class="powerup-icon" src="/static/icons/shuffle.png" />
        <text class="powerup-count">{{powerUps.shuffle}}</text>
      </view>
      <view class="powerup-item" bindtap="onUsePowerUp" data-type="revive">
        <image class="powerup-icon" src="/static/icons/revive.png" />
        <text class="powerup-count">{{powerUps.revive}}</text>
      </view>
    </view>
  </view>

  <!-- 游戏结束弹窗 -->
  <view class="modal-overlay" wx:if="{{showGameOver}}">
    <view class="modal-content game-over-modal">
      <text class="modal-title">游戏结束</text>
      <text class="modal-score">得分：{{score}}</text>
      <text class="modal-moves">步数：{{moves}}</text>
      <view class="modal-buttons">
        <button class="btn-restart" bindtap="onRestart">重新开始</button>
        <button class="btn-share" open-type="share">分享</button>
      </view>
    </view>
  </view>

  <!-- 关卡完成弹窗 -->
  <view class="modal-overlay" wx:if="{{showLevelComplete}}">
    <view class="modal-content level-complete-modal">
      <text class="modal-title">关卡完成！</text>
      <text class="modal-score">得分：{{score}}</text>
      <text class="modal-moves">步数：{{moves}}</text>
      <view class="modal-buttons">
        <button class="btn-next" bindtap="onNextLevel">下一关</button>
        <button class="btn-share" open-type="share">分享</button>
      </view>
    </view>
  </view>
</view>
