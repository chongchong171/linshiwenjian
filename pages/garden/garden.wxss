/* pages/garden/garden.wxss */

page {
  background: #f5f0e1;
}

.container {
  min-height: 100vh;
  padding: 40rpx 24rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2e7d32;
  display: block;
  margin-bottom: 8rpx;
}

.count {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* ========== 空状态 ========== */

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #aaa;
}

/* ========== 植物网格 ========== */

.garden-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.plant-card {
  width: 180rpx;
  height: 200rpx;
  background: white;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.plant-card.rare {
  border: 2rpx solid #64b5f6;
  background: linear-gradient(135deg, #f0f8ff, #e3f2fd);
}

.plant-card.legendary {
  border: 2rpx solid #ffd54f;
  background: linear-gradient(135deg, #fff8e1, #ffecb3);
}

.plant-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.plant-name {
  font-size: 24rpx;
  color: #333;
}

.plant-rarity {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 24rpx;
}
