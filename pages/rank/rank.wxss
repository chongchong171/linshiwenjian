/* pages/rank/rank.wxss */

page {
  background: #f5f0e1;
}

.container {
  min-height: 100vh;
  padding: 40rpx 24rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2e7d32;
  display: block;
  margin-bottom: 8rpx;
}

.date {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.rank-item.top {
  background: linear-gradient(135deg, #fff8e1, #fff);
  border: 1rpx solid #ffe082;
}

.rank-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #666;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.rank-num.gold {
  background: linear-gradient(135deg, #ffd54f, #ffb300);
  color: white;
}

.rank-num.silver {
  background: linear-gradient(135deg, #bdbdbd, #9e9e9e);
  color: white;
}

.rank-num.bronze {
  background: linear-gradient(135deg, #ff8a65, #e64a19);
  color: white;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rank-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.rank-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.rank-props {
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
}

.my-rank {
  margin-top: 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
  border-radius: 16rpx;
  text-align: center;
}

.my-rank-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.my-rank-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #2e7d32;
  display: block;
}
